# === Vercel + Neon PostgreSQL 部署配置 ===

# Neon 数据库连接 (从 Vercel Dashboard → Storage → Neon 获取)
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT 密钥 (生产环境请使用长随机字符串)
JWT_SECRET=your-production-secret-key-here
JWT_EXPIRE_MINUTES=120

# CORS 允许的域名 (部署后填写 Vercel 域名)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Redis (可选, Vercel 上可用 Upstash Redis)
REDIS_URL=redis://localhost:6379/0

# 模型路径 (Vercel serverless 环境用 /tmp)
ONNX_MODEL_PATH=/tmp/models
TORCHSERVE_URL=http://localhost:8080

# 调试模式
DEBUG=false
