# 腐蚀与应力在线监测平台 V2.0 - Backend Environment
APP_NAME=腐蚀与应力在线监测平台 V2.0
DEBUG=false

# PostgreSQL (async: postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/soundsofts
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/soundsofts

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - CHANGE IN PRODUCTION
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model paths
ONNX_MODEL_PATH=./model-serving/onnx_models
TORCHSERVE_URL=http://localhost:8080
MLFLOW_TRACKING_URI=http://localhost:5000

# File storage
UPLOAD_DIR=./uploads
REPORT_OUTPUT_DIR=./reports
