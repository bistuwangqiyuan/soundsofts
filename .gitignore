# ============================================================
# 聚乙烯补口粘接检测全套软件系统 — 根目录 .gitignore
# Monorepo: Python (FastAPI/ML/信号处理) + Node.js (React)
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# 虚拟环境
.venv/
venv/
ENV/

# 打包与分发
*.egg-info/
*.egg
dist/
build/
*.whl

# 测试与覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ---------- Node.js ----------
node_modules/
.pnp
.pnp.js

# ---------- 构建产物 ----------
platform/frontend/dist/
*.next/
out/

# ---------- 数据库 ----------
*.sqlite
*.sqlite3
*.db
test_db.*

# ---------- 环境变量 ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
!.env.example

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- 日志 ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- 安全相关 ----------
*.pem
*.key
*.crt
*.p12

# ---------- 模型文件（大文件，使用 Git LFS 或单独管理）----------
*.onnx
*.pt
*.pth
*.mar
*.h5
*.hdf5
*.pkl
*.joblib

# ---------- 运行时生成目录 ----------
uploads/
reports/
logs/
tmp/

# ---------- Vercel / Netlify ----------
.vercel
.netlify

# ---------- 其他 ----------
.cache
.stackbit/cache
